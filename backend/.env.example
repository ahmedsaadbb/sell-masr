# Application
APP_NAME=SellMasr
APP_VERSION=0.1.0
DEBUG=True

# Database
# Use sqlite:///./sellmasr.db for development
DATABASE_URL=sqlite:///./sellmasr.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
# Run `openssl rand -hex 32` to generate a strong SECRET_KEY
SECRET_KEY=your-secret-key-change-in-production-12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
# List of origins allowed to make requests to the API
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:5173"]

# External APIs
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_IFRAME_ID=your_paymob_iframe_id
OPENAI_API_KEY=your_openai_api_key

# Encryption (Used for sensitive settings in DB)
ENCRYPTION_KEY=AIzaSyBUALqAXZ4y4vdJSlKcN019VqFuttJ5DzE
